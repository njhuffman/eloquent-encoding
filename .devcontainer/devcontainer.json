{
  "name": "Eloquence (Chess / Python)",
  "build": {
    "context": "..",
    "dockerfile": "Dockerfile"
  },
  "runArgs": ["--gpus", "all"],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },
  "remoteUser": "vscode",
  "postCreateCommand": "pip install --no-cache-dir -r requirements.txt"
}
